	eprint = {1405.1178 [math.SG]},
	keywords = {Mathematics - Symplectic Geometry},
	file = {Preprint PDF:C\:\\Users\\coren\\Zotero\\storage\\A36LGUZ3\\Chiu - 2017 - Non-squeezing property of contact balls.pdf:application/pdf;Snapshot:C\:\\Users\\coren\\Zotero\\storage\\K7GKP4L6\\1405.html:text/html},
