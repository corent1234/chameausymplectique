	urldate = {2026-05-12},
	date = {2025-04-15},
	eprinttype = {arxiv},
	eprint = {2310.11993 [math.SG]},
	keywords = {Mathematics - Geometric Topology, Mathematics - Symplectic Geometry},
	file = {Preprint PDF:C\:\\Users\\coren\\Zotero\\storage\\RJUKJBFQ\\Fraser et al. - 2025 - Contact non-squeezing at large scale via generatin.pdf:application/pdf;Snapshot:C\:\\Users\\coren\\Zotero\\storage\\RLFCQ4IN\\2310.html:text/html},
