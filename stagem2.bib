@article{fraser_contact_2015,
	title = {Contact non-squeezing at large scale in \$\{{\textbackslash}mathbb R\}{\textasciicircum}\{2n\} {\textbackslash}times S{\textasciicircum}1\$},
	url = {https://www.semanticscholar.org/paper/Contact-non-squeezing-at-large-scale-in-%24%7B%5Cmathbb-Fraser/e8265e096a321f4396ea80234b32f66ceeeeb7d4},
	abstract = {We define a \${\textbackslash}mathbb\{Z\}\_k\$-equivariant version of the cylindrical contact homology used by Eliashberg-Kim-Polterovich (2006) to prove contact non-squeezing for prequantized integer-capacity balls \$B(R) {\textbackslash}times S{\textasciicircum}1 {\textbackslash}subset {\textbackslash}mathbb\{R\}{\textasciicircum}\{2n\} {\textbackslash}times S{\textasciicircum}1\$, \$R {\textbackslash}in {\textbackslash}mathbb\{N\}\$ and we use it to extend their result to all \$R {\textbackslash}geq 1\$. Specifically we prove if \$R {\textbackslash}geq 1\$ there is no \${\textbackslash}psi{\textbackslash}in {\textbackslash}text\{Cont\}({\textbackslash}mathbb\{R\}{\textasciicircum}\{2n\} {\textbackslash}times S{\textasciicircum}1)\$, the group of compactly supported contactomorphisms of \${\textbackslash}mathbb\{R\}{\textasciicircum}\{2n\} {\textbackslash}times S{\textasciicircum}1\$ which squeezes \${\textbackslash}hat\{B\}(R) = B(R) {\textbackslash}times S{\textasciicircum}1\$ into itself, i.e. maps the closure of \${\textbackslash}hat\{B\}(R)\$ into \${\textbackslash}hat\{B\}(R)\$. A sheaf theoretic proof of non-existence of corresponding \${\textbackslash}psi {\textbackslash}in {\textbackslash}text\{Cont\}\_0({\textbackslash}mathbb\{R\}{\textasciicircum}\{2n\} {\textbackslash}times S{\textasciicircum}1)\$, the identity component of \${\textbackslash}text\{Cont\}({\textbackslash}mathbb\{R\}{\textasciicircum}\{2n\} {\textbackslash}times S{\textasciicircum}1)\$, is due to Chiu (2014); it is not known if this is strictly weaker. Our construction has the advantage of retaining the contact homological viewpoint of Eliashberg-Kim-Polterovich and its potential for application in prequantizations of other Liouville manifolds. It makes use of the \${\textbackslash}mathbb\{Z\}\_k\$-action generated by a vertical \$1/k\$-shift but can also be related, for prequantized balls, to the \${\textbackslash}mathbb\{Z\}\_k\$-equivariant contact homology developed by Milin (2008) in her proof of orderability of lens spaces.},
	journaltitle = {{arXiv}: Symplectic Geometry},
	author = {Fraser, M.},
	urldate = {2026-06-03},
	date = {2015-12-30},
	file = {Full Text PDF:C\:\\Users\\coren\\Zotero\\storage\\SNNU55GK\\Fraser - 2015 - Contact non-squeezing at large scale in \$ mathbb R ^ 2n times S^1\$.pdf:application/pdf},
}
