	doi = {10.1215/00127094-3715517},
	abstract = {In this paper we solve a contact non-squeezing conjecture proposed by Eliashberg, Kim and Polterovich. Let \$B\_R\$ be the open ball of radius \$R\$ in \${\textbackslash}mathbf\{R\}{\textasciicircum}\{2n\}\$ and let \${\textbackslash}mathbf\{R\}{\textasciicircum}\{2n\}{\textbackslash}times{\textbackslash}mathbf\{S\}{\textasciicircum}1\$ be the prequantization space equipped with the standard contact structure. Following Tamarkin's idea, we apply microlocal category methods to prove that if \$R\$ and \$r\$ satisfy \$1{\textbackslash}leqπr{\textasciicircum}2{\textless}πR{\textasciicircum}2\$, then it is impossible to squeeze the contact ball \$B\_R{\textbackslash}times{\textbackslash}mathbf\{S\}{\textasciicircum}1\$ into \$B\_r{\textbackslash}times{\textbackslash}mathbf\{S\}{\textasciicircum}1\$ via compactly supported contact isotopies.},
	number = {4},
